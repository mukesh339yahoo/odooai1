<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_field_security_rule_form" model="ir.ui.view">
        <field name="name">field.security.rule.form</field>
        <field name="model">field.security.rule</field>
        <field name="arch" type="xml">
            <form string="Field &amp; UI Security Rule">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active == True"/>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="model_id" options="{'no_create': True}"/>
                            <field name="target_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="field_id" options="{'no_create': True}" 
                                   context="{'default_model_id': model_id}"
                                   invisible="target_type != 'field'"
                                   required="target_type == 'field'"/>
                            <field name="button_name" 
                                   invisible="target_type != 'button'"
                                   required="target_type == 'button'"/>
                            <field name="rule_type"/>
                            <field name="view_type"/>
                            <field name="domain" placeholder="e.g. [('state', '=', 'done')]"/>
                        </group>
                        <group>
                            <field name="apply_behavior" widget="radio" options="{'horizontal': true}"/>
                            <field name="group_ids" widget="many2many_tags" placeholder="Groups..."/>
                            <field name="user_ids" widget="many2many_tags" placeholder="Specific Users..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_field_security_rule_tree" model="ir.ui.view">
        <field name="name">field.security.rule.list</field>
        <field name="model">field.security.rule</field>
        <field name="arch" type="xml">
            <tree string="Field Security Rules">
                <field name="model_id"/>
                <field name="target_type"/>
                <field name="field_id" optional="show"/>
                <field name="button_name" optional="show"/>
                <field name="rule_type"/>
                <field name="apply_behavior"/>
                <field name="view_type"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_field_security_rule_search" model="ir.ui.view">
        <field name="name">field.security.rule.search</field>
        <field name="model">field.security.rule</field>
        <field name="arch" type="xml">
            <search string="Search Rules">
                <field name="model_id"/>
                <field name="field_id"/>
                <field name="button_name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Group By Model" name="group_by_model" domain="[]" context="{'group_by': 'model_id'}"/>
                <filter string="Group By Target Type" name="group_by_target" domain="[]" context="{'group_by': 'target_type'}"/>
                <filter string="Group By Rule Type" name="group_by_rule_type" domain="[]" context="{'group_by': 'rule_type'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_field_security_rule" model="ir.actions.act_window">
        <field name="name">UI &amp; Field Security Rules</field>
        <field name="res_model">field.security.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first UI security rule!
            </p>
            <p>
                Use rules to hide, make read-only, or require specific fields and buttons for certain user groups without custom code.
            </p>
        </field>
    </record>

    <!-- Menu Item under Settings > Technical > Security -->
    <menuitem id="menu_field_security_rule"
              name="Field Security Rules"
              parent="base.menu_security"
              action="action_field_security_rule"
              sequence="100"/>

</odoo>
